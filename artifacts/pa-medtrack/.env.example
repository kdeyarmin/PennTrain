# Local dev: copy to .env in this directory and fill in your Supabase
# project's URL and anon/publishable key (Supabase dashboard -> Project
# Settings -> API). See ../../DEPLOYMENT.md for production setup on Railway.
#
# Never put SUPABASE_SERVICE_ROLE_KEY here or anywhere under this package --
# only Vite-prefixed vars belong in a Vite app's env, and this key must never
# reach browser-shipped code.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional, build-time only, needed only when serving from a non-root subpath (see
# vite.config.ts). Leave unset for a normal deployment.
# BASE_PATH=/

# Do NOT set VITE_OPENAI_API_KEY here. src/lib/caremetricAi.ts's own fallback message
# suggests it, but any VITE_-prefixed var ships in the public bundle -- see the root
# .env.example for why that's unsafe for an unscoped, billable key like this one.
