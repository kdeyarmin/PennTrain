  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "pnpm --filter @workspace/scripts run generate:manual && vite build --config vite.config.ts && node server/prerender-heads.mjs && node server/precompress.mjs",
