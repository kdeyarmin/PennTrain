# Local dev: copy to .env in this directory and fill in your Supabase
# project's URL and anon/publishable key (Supabase dashboard -> Project
# Settings -> API). See ../../DEPLOYMENT.md for production setup on Railway.
#
# Never put SUPABASE_SERVICE_ROLE_KEY here or anywhere under this package --
# only Vite-prefixed vars belong in a Vite app's env, and this key must never
# reach browser-shipped code.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key

# Optional production telemetry controls. Client reports are PHI-scrubbed and sent to the
# report-client-error Supabase Edge Function; production reporting defaults to enabled.
# VITE_CLIENT_ERROR_REPORTING_ENABLED=true
# VITE_RELEASE_ID=git-commit-sha

# Optional. Leave unset unless this environment intentionally exposes demo login buttons.
# VITE_DEMO_ACCOUNTS_JSON='[{"label":"Org Admin","email":"admin@example.com","password":"...","color":"bg-blue-500"}]'

# Optional, build-time only, needed only when serving from a non-root subpath (see
# vite.config.ts). Leave unset for a normal deployment.
# BASE_PATH=/

# Optional override for the landing-page overview video (an AI-avatar presenter
# generated with HeyGen — see scripts/heygen/generate-landing-video.mjs and
# docs/marketing/landing-video-script.md). The video + poster ship as committed assets
# under public/marketing and are shown by default, so this is only needed to serve the
# media from a CDN / public bucket instead of the app's own origin (e.g. to keep the
# large binary off the app host). Browser-safe (just a public media URL).
# VITE_LANDING_VIDEO_URL=https://your-cdn.example.com/landing-overview.mp4
# VITE_LANDING_VIDEO_POSTER_URL=https://your-cdn.example.com/landing-overview-poster.jpg

# Optional. Base URL of the shared voice gateway (artifacts/voice-gateway). When unset the
# voice assistant UI is hidden entirely; when set, the Voice tab appears on the Regulatory
# Copilot page for grounded-copilot roles. Browser-safe (it is just a URL — auth uses the
# caller's Supabase JWT).
# VITE_VOICE_GATEWAY_URL=https://your-voice-gateway.up.railway.app
