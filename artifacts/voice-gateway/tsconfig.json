{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // This package runs on Node directly (no bundler), so resolution must
    // follow Node's ESM rules — relative imports carry .js extensions.
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
