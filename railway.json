{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile --prod=false && pnpm --filter @workspace/caremetric-carebase run typecheck && pnpm --filter @workspace/caremetric-carebase run build && node scripts/check-bundle-budget.mjs",
    "watchPatterns": [
      "artifacts/caremetric-carebase/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "railway.json",
      "railpack.json",
      "tsconfig.base.json",
      ".node-version",
      ".nvmrc",
      ".npmrc",
      "scripts/check-bundle-budget.mjs"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/caremetric-carebase run start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
