# CareMetric CareBase -- production environment variables
#
# This app has no backend server of its own: the React SPA in
# artifacts/caremetric-carebase talks to Supabase directly via supabase-js, and
# Supabase Edge Functions (supabase/functions/*) handle anything that needs
# the service-role key or an outbound API call (user provisioning, CSV
# import, PDF generation, HeyGen video generation).
#
# Railway hosts and runs the app below. Set these as Railway service
# variables (Project -> Service -> Variables), NOT by committing a real
# .env file. See DEPLOYMENT.md for the full setup walkthrough.

# --- Supabase (browser-safe, required) ---------------------------------
# Vite only exposes env vars prefixed VITE_ to the client bundle. The anon
# key is safe to ship to the browser: it has no access beyond what Row
# Level Security grants an unauthenticated/authenticated request.
#
# BUILD-TIME: both values are baked into the JS bundle when `vite build`
# runs (the build fails loudly if they're missing). Changing them on the
# Railway service requires a redeploy (rebuild), not just a restart.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key

# Optional build-time product allow-list. Leave unset for a universal build whose organization
# package decides access. Use "train" for a standalone CareMetric Train deployment or "carebase"
# for the complete CareMetric CareBase deployment (CareBase includes Train automatically).
# VITE_CAREMETRIC_MODULES=train

# Temporary rolling-deploy bridge only. Leave unset/false in production; setting true lets the
# frontend preserve pre-module access if the database has not returned module entitlement rows yet.
# VITE_CAREMETRIC_ALLOW_LEGACY_MODULE_FAIL_OPEN=false

# Optional, build-time only. Leave unset in production unless you intentionally operate a public
# demo environment. Value is a JSON array of { "label", "email", "password", "color" } objects.
# VITE_DEMO_ACCOUNTS_JSON='[{"label":"Organization admin","email":"demo-admin@example.com","password":"...","role":"org_admin","description":"Explore organization setup, staffing, and compliance."}]'

# --- App runtime -----------------------------------------------------------
# Railway injects PORT automatically; only set it locally if you need a
# specific port. NODE_ENV is set by Railway's Railpack builder automatically
# too, so setting it yourself is optional/harmless.
# PORT=8080
# HOST is optional; server/index.mjs binds dual-stack "::" by default.
NODE_ENV=production

# APP_URL is not read by the app at runtime (the browser's own origin is
# used for Supabase Auth redirect links, see
# artifacts/caremetric-carebase/src/pages/auth/ForgotPassword.tsx).
# It's listed here as documentation of the production URL. Both origins the
# app is served from must be in Supabase Auth -> URL Configuration ->
# Redirect URLs: https://cmcarebase.com/login,
# https://cmcarebase.com/, and the matching Railway /login + root URLs.
# The root callback is used by enterprise SSO after Supabase verifies the SAML response.
# APP_URL=https://cmcarebase.com

# BASE_PATH is an optional, build-time-only override read by vite.config.ts
# (feeds Vite's `base` option, which the wouter router reads back via
# import.meta.env.BASE_URL). Only needed if the SPA is ever served from a
# non-root subpath; leave unset for a standard Railway root-domain deploy,
# where it correctly defaults to "/".
# BASE_PATH=/

# --- Explicitly NOT used by this app (do not add) --------------------------
# SUPABASE_SERVICE_ROLE_KEY   -- lives ONLY in Supabase Edge Function
#                                secrets (`supabase secrets set ...`), never
#                                in Railway or any client-reachable process.
#                                Guardrail: server/index.mjs and every file
#                                under src/ must never reference this name.
# DATABASE_URL                -- no direct Postgres access from app code;
#                                everything goes through supabase-js + RLS.
# NEXT_PUBLIC_SUPABASE_URL/ANON_KEY -- this is a Vite app, not Next.js.
# SESSION_SECRET / AUTH_SECRET -- auth/session state is Supabase Auth
#                                (GoTrue) via cookies/localStorage; the app
#                                has no server-side session of its own.
# NPM_CONFIG_PRODUCTION / RAILPACK_PRUNE_DEPS -- NEVER set these: every
#                                dependency of the app (including vite) is a
#                                devDependency, and either of these makes the
#                                install skip devDependencies, emptying the
#                                build. The buildCommand passes --prod=false
#                                as a guard, but don't fight it.
# SENDGRID_API_KEY / TWILIO_*  -- these power the training-reminder delivery
#                                engine (dispatch-notifications Edge
#                                Function), not the app server; set them as
#                                Supabase Edge Function secrets (see below),
#                                never as a Railway variable. Password
#                                reset/invite emails are separate -- those
#                                are sent by Supabase Auth's built-in mailer,
#                                configured via Authentication -> Emails ->
#                                SMTP Settings in the Supabase dashboard if
#                                you also want those routed through SendGrid.
# RAILWAY_PUBLIC_DOMAIN        -- Railway sets this automatically for
#                                Railway-provided domains; the app doesn't
#                                need to read it (see note above re: browser
#                                origin), but it's useful when scripting
#                                your own deploy tooling.

# --- Supabase Edge Function secrets (set via `supabase secrets set`, NOT
#     here -- these run on Supabase's infrastructure, not Railway) ---------
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# HEYGEN_API_KEY=
# ANTHROPIC_API_KEY=    -- required for AI course curriculum generation
#                          (generate-course-curriculum, regenerate-course-block);
#                          set via `supabase secrets set ANTHROPIC_API_KEY=...`,
#                          an Edge Function secret only -- never a client/Railway
#                          variable, exactly like HEYGEN_API_KEY above.
# SENDGRID_API_KEY=            -- email delivery for dispatch-notifications, send-auth-email, and
#                                  the email-savings-model marketing worksheet
# NOTIFICATION_FROM_EMAIL=     -- optional; "Name <email>" or plain email, defaults to
#                                  "CareMetric CareBase <notifications@cmcarebase.com>"
# PUBLIC_SITE_URL=             -- optional public site origin used in email-savings-model links;
#                                  defaults to https://cmcarebase.com
# TWILIO_ACCOUNT_SID=          -- used by dispatch-notifications for SMS delivery
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID= -- preferred over TWILIO_FROM_NUMBER when a Messaging Service
#                                  manages senders and Advanced Opt-Out.
# TWILIO_NOTIFICATION_STATUS_CALLBACK_URL= -- optional public override for the signed delivery
#                                  callback; defaults to the deployed twilio-notification-webhook.
# WEB_PUSH_VAPID_PUBLIC_KEY=   -- URL-safe public VAPID key returned only to authenticated
#                                  browsers by push-subscriptions.
# WEB_PUSH_VAPID_PRIVATE_KEY=  -- matching private VAPID key; Edge Function secret only.
# WEB_PUSH_VAPID_SUBJECT=      -- contact URI for the push service, for example
#                                  mailto:security@cmcarebase.com.
# SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY= -- ECDSA public key from SendGrid Event Webhook settings.
# NOTIFICATION_RECIPIENT_HASH_SECRET= -- random 32+ byte secret used to fingerprint opt-out
#                                  recipients without storing their address in consent evidence.
# SEND_EMAIL_HOOK_SECRET=      -- used by send-auth-email to verify Supabase Auth's Send Email
#                                  Hook webhook signature; generated by the dashboard when you
#                                  add the hook (Authentication -> Hooks), format "v1,whsec_..."
# CRON_SHARED_SECRET=          -- same random value stored in Supabase Vault as
#                                  `cron_shared_secret`; required by cron-only Edge Functions.
# TURNSTILE_SECRET_KEY=        -- Cloudflare Turnstile secret for signup-organization, request-demo,
#                                  subscribe-updates, and email-savings-model (public, session-less
#                                  intake functions).
# SIGNUP_RATE_LIMIT_PEPPER=    -- optional secret pepper for signup_attempts hashes; defaults to
#                                  the service-role key if omitted.
# NEWSLETTER_MAX_IP_REQUESTS_PER_HOUR= -- optional cap on new subscribe-updates signups per hashed
#                                  IP per hour; defaults to 5.
# NEWSLETTER_RATE_LIMIT_PEPPER= -- optional secret pepper for newsletter_subscribers ip_hash;
#                                  defaults to DEMO_RATE_LIMIT_PEPPER, then the service-role key.
# SITE_URL=                    -- optional public marketing origin used in outbound subscribe-updates
#                                  welcome-email links; defaults to https://cmcarebase.com.
# SIGNUP_REDIRECT_ORIGINS=     -- comma-separated app origins allowed for signup invite redirects,
#                                  e.g. https://cmcarebase.com,https://carebase-production.up.railway.app
# PUBLIC_APP_URL=              -- fallback origin used in signup invite links.
# ALLOW_LOCALHOST_SIGNUP_REDIRECTS=true -- optional for local development only; never set in
#                                  production because invite links should not redirect to localhost.
# STRIPE_SECRET_KEY=           -- Stripe server API key used only by create-billing-session.
# STRIPE_BILLING_WEBHOOK_SECRET= -- signing secret for the stripe-billing-webhook endpoint.
# BILLING_RETURN_URL_ORIGINS=  -- optional comma-separated redirect-origin allowlist for Checkout
#                                  and Customer Portal, e.g. https://cmcarebase.com.
#
# SCIM credentials, integration API keys, and tenant outbound-webhook signing secrets are issued
# through the Phase 2 control-plane RPCs. Their plaintext value is returned only at issuance or
# rotation; only salted hashes (or Vault references for outbound signing) are retained. They are
# tenant secrets, not application-wide environment variables.
